<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Pass Authorization header to PHP (mod_php and CGI compatibility)
    RewriteCond %{HTTP:Authorization} ^(.*)
    RewriteRule .* - [e=HTTP_AUTHORIZATION:%1]

    # Also expose Authorization for FastCGI / PHP-CGI mode (XAMPP)
    SetEnvIf Authorization "(.*)" HTTP_AUTHORIZATION=$1

    # Prevent directory listing
    Options -Indexes
    
    # Redirect root to public directory
    RewriteCond %{REQUEST_URI} ^/tour1/?$
    RewriteRule ^(.*)$ public/index.php [L]
    
    # Route /api/ to the new API entry point
    RewriteCond %{REQUEST_URI} ^/tour1/api/?
    RewriteRule ^api/(.*)$ api/index.php [L,QSA]

    # Redirect all other requests to the public directory
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ public/index.php?url=$1 [L,QSA]
</IfModule>

# Prevent directory listing if mod_rewrite is not available
Options -Indexes

